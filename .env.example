# ============================================================
# ÓTICAS MASTER — Variáveis de Ambiente
# Copie este arquivo para .env.local para desenvolvimento
# Configure estas variáveis no painel da Vercel para produção
# ============================================================

# --- SUPABASE (banco de dados) ---
# Obtenha em: https://supabase.com → Seu projeto → Settings → API
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Usada apenas nas Serverless Functions (não exposta ao front-end)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# --- JWT (autenticação do admin) ---
# Gere uma chave segura: openssl rand -base64 64
JWT_SECRET=sua_chave_jwt_super_secreta_aqui_minimo_32_caracteres

# --- MERCADO PAGO (pagamentos) ---
# Obtenha em: https://www.mercadopago.com.br/developers
MP_ACCESS_TOKEN=seu_access_token_mercado_pago
MP_PUBLIC_KEY=sua_public_key_mercado_pago

# --- RESEND (e-mails transacionais) ---
# Obtenha em: https://resend.com
RESEND_API_KEY=sua_api_key_resend

# --- CONFIGURAÇÕES GERAIS ---
NEXT_PUBLIC_SITE_URL=https://oticasmaster.com.br
